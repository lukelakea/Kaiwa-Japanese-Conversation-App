# Copy to .env and adjust as needed. All values have sensible defaults.

# --- LLM provider selection ---
# "ollama" (local, default) or "anthropic" (cloud, opt-in). Local-first: the app
# runs fully offline against Ollama unless this is switched to anthropic.
KAIWA_LLM_PROVIDER=ollama

# --- Ollama ---
# gemma3:27b is the default: it stays reliably in Japanese. qwen2.5:32b is also
# strong but intermittently code-switches to Chinese; swap here to try others.
KAIWA_OLLAMA_BASE_URL=http://localhost:11434
KAIWA_OLLAMA_MODEL=gemma3:27b

# --- Anthropic (only used when KAIWA_LLM_PROVIDER=anthropic) ---
# Requires the optional dependency: `uv sync --extra anthropic`. The key is held
# server-side and never sent to the browser. Sonnet 4.6 is the default (good
# quality/cost for conversation); claude-opus-4-8 for maximum quality.
# KAIWA_ANTHROPIC_API_KEY=sk-ant-...
# KAIWA_ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Generation defaults ---
KAIWA_TEMPERATURE=0.7
# Translation (Phase 2) runs cooler to stay literal and faithful to the reply.
KAIWA_TRANSLATION_TEMPERATURE=0.3
# Feedback (Phase 3) runs cool for consistent, well-formed structured output.
KAIWA_FEEDBACK_TEMPERATURE=0.3

# --- Reading aids (Phase 2) ---
# Path to the compiled JMdict + KANJIDIC2 SQLite, relative to the backend root.
# Build it with `npm run setup:dict`. Hover-lookup is empty until it exists.
KAIWA_DICTIONARY_PATH=data/dictionary.sqlite

# --- User-data store ---
# Where the frontend's saved data (vocab, conversation history, custom scenarios,
# grammar log, app settings) is persisted, relative to the backend root. Stored
# server-side rather than in browser localStorage so it survives a cleared
# browser. The data never leaves the machine.
KAIWA_DATA_DIR=data/store

# --- CORS (comma-separated origins allowed to call this API) ---
# Add the deployed frontend's origin here on the hosted demo.
KAIWA_CORS_ORIGINS=http://localhost:5173

# --- Rate limiting ---
# Comma-separated slowapi limit strings, applied per client IP. Empty (default)
# disables limiting — correct for the local single-user app. On the public demo,
# set something like "30/minute,500/hour" to cap abuse of the cloud providers.
KAIWA_RATE_LIMIT=

# --- Voice provider selection ---
# TTS: "voicevox" (local, default) or "google" (cloud).
# STT: "whisper" (local, default) or "google" (cloud).
# Both default to the local engine; switch to "google" for the hosted demo where
# VOICEVOX and a GPU aren't available. Both cloud options share one Google key.
KAIWA_TTS_PROVIDER=voicevox
KAIWA_STT_PROVIDER=whisper

# Google Cloud API key (only used when a provider above is "google"). Held
# server-side, never sent to the browser. Needs Text-to-Speech and/or
# Speech-to-Text enabled on the GCP project.
# KAIWA_GOOGLE_CLOUD_API_KEY=
# KAIWA_GOOGLE_TTS_VOICE=ja-JP-Neural2-B

# --- Voice (Phase 5) ---
# VOICEVOX must be running before TTS is used (only when KAIWA_TTS_PROVIDER=voicevox).
# See VOICEVOX's speaker list or GET /api/tts/speakers for available IDs.
KAIWA_VOICEVOX_BASE_URL=http://localhost:50021
KAIWA_VOICEVOX_SPEAKER=2

# faster-whisper model size. Options: tiny, base, small, medium, large-v3.
# "base" is fast and accurate for clear conversational Japanese on GPU.
# KAIWA_WHISPER_DEVICE=cuda and KAIWA_WHISPER_COMPUTE_TYPE=float16 are optimal
# for NVIDIA GPUs; use "cpu" + "int8" if running without a GPU.
KAIWA_WHISPER_MODEL=base
KAIWA_WHISPER_DEVICE=cuda
KAIWA_WHISPER_COMPUTE_TYPE=float16
