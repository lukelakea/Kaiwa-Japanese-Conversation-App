# Copy to .env.local to override. Defaults work for local development.

# Base URL of the Kaiwa backend. On the hosted demo, point this at the deployed
# backend (e.g. https://kaiwa-api-xxxx.a.run.app).
VITE_API_BASE_URL=http://localhost:8000

# Where saved data (vocab, history, scenarios, grammar, settings) is persisted:
#   backend (default) — the local-first /api/store document store
#   local             — browser localStorage, for the public demo
VITE_STORAGE=backend

# Set to "false" on the public demo to hide "Design Your Own" scenarios. The
# custom scenario form lets users inject arbitrary instructions into the system
# prompt (via the "notes" field), which is acceptable locally but undesirable
# on a shared deployment. All other modes (Free Talk, Scenarios, Generated) remain.
VITE_ALLOW_CUSTOM_SCENARIOS=true
